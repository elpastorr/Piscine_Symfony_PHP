{% extends 'base.html.twig' %}

{% block body %}
<h1>Employees</h1>

<a href="{{ path('employee_create') }}">Create</a>

<table border="1">
<tr>
    <th>ID</th>
    <th>Name</th>
    <th>Email</th>
    <th>Manager</th>
    <th>Hours</th>
    <th>Position</th>
    <th>Modify</th>
</tr>

{% for e in employees %}
<tr>
    <td>{{ e.id }}</td>
    <td>{{ e.firstname }} {{ e.lastname }}</td>
    <td>{{ e.email }}</td>
    <td>
        {{ e.manager ? e.manager.firstname : 'None' }}
    </td>
    <td>{{ e.hours }}</td>
    <td>{{ e.position }}</td>
    <td>
        <a href="{{ path('employee_edit', {'id': e.id}) }}">
            <button>Edit</button>
        </a>

        <form method="post" action="{{ path('employee_delete', {'id': e.id}) }}" style="display:inline;">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ e.id) }}">
            <button type="submit" onclick="return confirm('Are you sure?');">
                Delete
            </button>
        </form>
    </td>
</tr>
{% else %}
<tr><td colspan="4">No employees</td></tr>
{% endfor %}

</table>
{% endblock %}