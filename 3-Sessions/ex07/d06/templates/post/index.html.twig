{% extends 'base.html.twig' %}

{% block title %}Posts{% endblock %}

{% block body %}
<h1>All Posts</h1>

{% if app.user %}
    <p><a href="{{ path('post_create') }}">Create New Post</a></p>
{% endif %}

<table>
    <thead>
        <tr>
            <th>Title</th>
            <th>Author</th>
            <th>Created</th>
        </tr>
    </thead>
    <tbody>
        {% for post in posts %}
            <tr>
                <td><a href="{{ path('post_show', {'id': post.id}) }}">{{ post.title }}</a></td>
                <td>{{ post.author.email }}</td>
                <td>{{ post.created|date('Y-m-d H:i') }}</td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3">No posts yet.</td>
            </tr>
        {% endfor %}
    </tbody>
</table>
{% endblock %}