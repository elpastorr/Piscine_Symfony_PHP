{% extends 'base.html.twig' %}

{% block title %}Hello HomeController!{% endblock %}

{% block body %}
<h1>Welcome{% if app.user %}, {{ app.user.email }}{% endif %}!</h1>

{% if app.user %}
    <p><a href="{{ path('app_logout') }}">Logout</a></p>

    {% if is_granted('ROLE_ADMIN') %}
        <p><a href="{{ path('admin_users') }}">Manage Users</a></p>
    {% endif %}
{% else %}
    <p><a href="{{ path('app_login') }}">Login</a> | <a href="{{ path('app_register') }}">Register</a></p>
{% endif %}

<h2>Posts</h2>
{% if posts is defined and posts|length > 0 %}
    <ul>
        {% for post in posts %}
            <li>
                <a href="{{ path('post_show', {'id': post.id}) }}">{{ post.title }}</a>
                - by {{ post.author.email }}
                - {{ post.created|date('Y-m-d H:i') }}
            </li>
        {% endfor %}
    </ul>
{% else %}
    <p>No posts yet.</p>
{% endif %}
{% endblock %}
