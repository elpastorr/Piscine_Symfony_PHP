{% extends 'base.html.twig' %}

{% block title %}{{ post.title }}{% endblock %}

{% block body %}
<h1>{{ post.title }}</h1>
<p>By {{ post.author.email }} on {{ post.created|date('Y-m-d H:i') }}</p>
<div>
    {{ post.content|nl2br }}
</div>
<a href="{{ path('post_list') }}">Back to posts</a>
{% endblock %}