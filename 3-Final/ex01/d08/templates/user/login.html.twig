{% extends 'base.html.twig' %}

{% block body %}
<form id="login-form">
    <input type="text"     name="_username" placeholder="Username" required />
    <input type="password" name="_password" placeholder="Password" required />
    <button type="submit">Log in</button>
</form>

<script>
document.getElementById('login-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    const data = new FormData(this);

    const res = await fetch('{{ path('app_login_check') }}', {
        method: 'POST',
        body: data,
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    });

    const json = await res.json();
    if (json.success) {
        window.location.href = '{{ path('app_post_index') }}';
    } else {
        alert(json.message || 'Invalid credentials.');
    }
});
</script>
{% endblock %}