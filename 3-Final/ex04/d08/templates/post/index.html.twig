{% extends 'base.html.twig' %}

{% block body %}

<div id="post-details"></div>

{% if is_logged_in %}
    {{ form_start(post_form, {'attr': {'id': 'post-form'}}) }}
        {{ form_row(post_form.title) }}
        {{ form_row(post_form.content) }}
        <button type="submit">{{ 'post.submit'|trans }}</button>
    {{ form_end(post_form) }}

    <div id="post-message" style="display:none;"></div>
{% else %}
    {{ render(controller('App\\Controller\\UserController::loginAction')) }}
{% endif %}

<h2>{{ 'post.list.title'|trans }}</h2>

{% if posts is empty %}
    <p id="no-posts">{{ 'post.list.empty'|trans }}</p>
{% endif %}

<ul id="post-list">
    {% for post in posts %}
        <li data-id="{{ post.id }}">
            <strong class="post-title" style="cursor:pointer;">
                {{ post.title }}
            </strong>
            <small>{{ post.created|date('d/m/Y H:i') }}</small>
        </li>
    {% endfor %}
</ul>

{% if is_logged_in %}
<script>

// WebSocket
const ws = new WebSocket('ws://127.0.0.1:8080');
ws.onopen  = () => console.log('WebSocket connected');
ws.onerror = (err) => console.error('WebSocket error:', err);

ws.onmessage = function(event) {
    const data = JSON.parse(event.data);

    if (data.type === 'new_post') {
        const noPostsEl = document.getElementById('no-posts');
        if (noPostsEl) noPostsEl.style.display = 'none';

        const li = document.createElement('li');
        li.setAttribute('data-id', data.post.id);
        li.innerHTML = `
            <strong class="post-title" style="cursor:pointer;">${data.post.title}</strong>
            <small>${data.post.created}</small>
        `;
        li.querySelector('.post-title').addEventListener('click', function() {
            viewPost(data.post.id);
        });
        document.getElementById('post-list').appendChild(li);
    }

    if (data.type === 'delete_post') {
        const li = document.querySelector(`li[data-id="${data.id}"]`);
        if (li) li.remove();
        document.getElementById('post-details').innerHTML = '';
    }
};

// Post form
document.getElementById('post-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    const data = new FormData(this);
    const res  = await fetch('{{ path("app_post_index") }}', {
        method: 'POST',
        body: data,
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    });
    const text = await res.text();
    try {
        const json = JSON.parse(text);
        if (json.success) {

            const msg = document.getElementById('post-message');
            msg.style.display = 'block';
            msg.textContent   = '{{ "post.success"|trans }}';
            this.reset();
            setTimeout(() => msg.style.display = 'none', 3000);
        } else {
            alert(json.message);
        }
    } catch (err) {
        alert('Unexpected error. Check the console.');
        console.error(text);
    }
});

// View post
async function viewPost(id) {
    const res  = await fetch(`/view/${id}`, {
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    });
    const json = await res.json();
    if (json.success) {
        const post = json.post;
        document.getElementById('post-details').innerHTML = `
            <h3>${post.title}</h3>
            <p>${post.content}</p>
            <small>${post.created}</small>
            {% if is_logged_in %}
            <br><button onclick="deletePost(${post.id})">Delete</button>
            {% endif %}
        `;
    }
}

document.querySelectorAll('.post-title').forEach(el => {
    el.addEventListener('click', function() {
        const id = this.closest('li').dataset.id;
        viewPost(id);
    });
});

// Delete post
async function deletePost(id) {
    if (!confirm('Are you sure?')) return;
    const res  = await fetch(`/delete/${id}`, {
        method: 'DELETE',
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    });
    const json = await res.json();
}
</script>
{% endif %}

{% endblock %}