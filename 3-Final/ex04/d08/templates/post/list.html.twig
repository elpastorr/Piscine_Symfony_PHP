{% extends 'base.html.twig' %}

{% block body %}
<h1>Posts</h1>

{% if posts is empty %}
    <p>No posts yet.</p>
{% else %}
    {% for post in posts %}
        <article>
            <h2>{{ post.title }}</h2>
            <p>{{ post.content }}</p>
            {% if post.created is defined %}
                <small>{{ post.created|date('d/m/Y H:i') }}</small>
            {% endif %}
        </article>
    {% endfor %}
{% endif %}

<a href="{{ path('app_post_index') }}">← Back</a>
{% endblock %}